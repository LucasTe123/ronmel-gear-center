rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regla global: nadie sin auth accede a nada por defecto
    match /{document=**} {
      allow read, write: if false;
    }

    // Datos privados del usuario — solo él accede
    match /users/{userId}/{col}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cache público para el Atajo de Siri — solo lectura pública
    // Solo el propio usuario puede escribirlo
    match /shortcut_cache/{userId} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Acciones pendientes del Atajo — escritura pública con token
    // Solo el propio usuario puede leer/eliminar
    match /shortcut_actions/{userId}/pending/{actionId} {
      allow create: if request.resource.data.token is string
                    && request.resource.data.token.size() > 0;
      allow read, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
